# Database
DATABASE_URL="postgresql://jobpilot:jobpilot@localhost:5432/jobpilot?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron / Worker
CRON_SECRET="generate-with-openssl-rand-base64-32"
JOB_INGESTION_CRON="0 */6 * * *"

# Job Sources — set to "false" to disable
JOB_SOURCE_REMOTEOK_ENABLED=true
JOB_SOURCE_HIMALAYAS_ENABLED=true
JOB_SOURCE_JOBICY_ENABLED=true
JOB_SOURCE_WWR_ENABLED=true
JOB_SOURCE_GREENHOUSE_ENABLED=true
JOB_SOURCE_LEVER_ENABLED=true
JOB_SOURCE_ASHBY_ENABLED=true

# Board tokens (comma-separated slugs)
JOB_SOURCE_GREENHOUSE_BOARDS=stripe,figma,airbnb
JOB_SOURCE_LEVER_COMPANIES=netflix,shopify
JOB_SOURCE_ASHBY_BOARDS=anthropic,notion
